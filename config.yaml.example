# CUKTECH BLE Server Configuration
# Copy this file to config.yaml and fill in your values

ble:
  mac: "XX:XX:XX:XX:XX:XX"
  token: ""
  ble_key: ""

mqtt:
  host: "localhost"
  port: 1883
  username: ""
  password: ""
  keepalive: 60
  topic_prefix: "cuktech/charger"

server:
  host: "0.0.0.0"
  port: 8199
  command_timeout: 10.0
  reconnect_delay: 5.0
  settings_refresh_interval: 60.0
